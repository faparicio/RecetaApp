@page "/presion-arterial"
@inject PresionArterialService PresionService
@inject PacienteService PacienteService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Presión Arterial - RecetaApp</PageTitle>

@if (!string.IsNullOrEmpty(PacienteId))
{
    @* === Vista detalle: historial de un paciente === *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0" style="color: #1565C0;">Presión Arterial</h3>
            @if (pacienteActual != null)
            {
                <div class="text-muted mt-1">Paciente: <strong>@pacienteActual.Nombre</strong></div>
            }
        </div>
        <div class="d-flex gap-2">
            <button class="btn-modern btn-modern-secondary" @onclick='() => Navigation.NavigateTo("/presion-arterial")'>
                ← Todos
            </button>
            <button class="btn btn-outline-info" @onclick="ToggleChart" style="border-radius: 12px;">
                <span style="font-size: 1.1rem;">&#128200;</span> @(showChart ? "Ocultar" : "Gráfica")
            </button>
            <button class="btn btn-outline-success" @onclick="() => showImport = true" style="border-radius: 12px;">
                <span style="font-size: 1.1rem;">&#128206;</span> Importar
            </button>
            <button class="btn btn-outline-primary" @onclick="ShowExportPanel" style="border-radius: 12px;">
                <span style="font-size: 1.1rem;">&#128190;</span> Exportar
            </button>
            <button class="btn-modern btn-modern-primary" @onclick="() => ShowNewForm()">
                + Nueva Medición
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        @if (showForm)
        {
            @RenderForm()
        }

        @if (showImport)
        {
            @RenderImportPanel()
        }

        @if (showExport)
        {
            @RenderExportPanel()
        }

        @if (showChart && pacienteMediciones.Count > 1)
        {
            <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-body p-3">
                    <div style="position: relative; height: 300px;">
                        <canvas id="presionChartCanvas"></canvas>
                    </div>
                </div>
            </div>
        }

        @if (pacienteMediciones.Count == 0 && !showForm)
        {
            <div class="text-center py-5">
                <p class="text-muted fs-5">No hay mediciones registradas</p>
                <button class="btn-modern btn-modern-primary" @onclick="() => ShowNewForm()">Registrar primera medición</button>
            </div>
        }
        else if (pacienteMediciones.Count > 0)
        {
            <div class="table-responsive" style="max-height: 500px; overflow-y: auto; border-radius: 12px;">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background: linear-gradient(135deg, #1565C0, #0D47A1); color: white; position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th class="px-3">Fecha</th>
                            <th class="px-3">Hora</th>
                            <th class="px-3 text-center">Sistólica</th>
                            <th class="px-3 text-center">Diastólica</th>
                            <th class="px-3 text-center">Pulso</th>
                            <th class="px-3">Clasificación</th>
                            <th class="px-3">Notas</th>
                            <th class="px-3 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in pacienteMediciones)
                        {
                            <tr>
                                <td class="px-3">@FormatFecha(m.Fecha)</td>
                                <td class="px-3">@(string.IsNullOrEmpty(m.Hora) ? "—" : m.Hora)</td>
                                <td class="px-3 text-center fw-bold">@m.Sistolica</td>
                                <td class="px-3 text-center fw-bold">@m.Diastolica</td>
                                <td class="px-3 text-center">@(m.Pulso > 0 ? m.Pulso.ToString() : "—")</td>
                                <td class="px-3">
                                    <span class="badge bg-@(m.ClasificacionColor == "orange" ? "warning" : m.ClasificacionColor)">
                                        @m.Clasificacion
                                    </span>
                                </td>
                                <td class="px-3 text-muted" style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @(string.IsNullOrEmpty(m.Notas) ? "—" : m.Notas)
                                </td>
                                <td class="px-3 text-center">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(m)">Editar</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(m)">Eliminar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}
else
{
    @* === Vista resumen: todos los pacientes === *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #1565C0;">Presión Arterial</h3>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (resumenPacientes.Count == 0)
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">No hay mediciones registradas</p>
            <p class="text-muted">Agrega mediciones desde la ficha de cada paciente</p>
            <button class="btn-modern btn-modern-secondary" @onclick='() => Navigation.NavigateTo("/pacientes")'>Ir a Pacientes</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var r in resumenPacientes)
            {
                var accentClass = r.Ultima.ClasificacionColor switch
                {
                    "success" => "accent-success",
                    "warning" => "accent-warning",
                    "danger" => "accent-danger",
                    _ => "accent-warning"
                };

                <div class="col-md-6 col-lg-4">
                    <div class="modern-card @accentClass" style="cursor: pointer;" @onclick='() => Navigation.NavigateTo($"/presion-arterial?pacienteId={r.PacienteId}")'>
                        <div class="card-body">
                            <div class="card-name">@r.PacienteNombre</div>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <div>
                                    <span style="font-size: 1.6rem; font-weight: 700; color: #1565C0;">@r.Ultima.Sistolica/@r.Ultima.Diastolica</span>
                                    <span class="text-muted ms-1" style="font-size: 0.85rem;">mmHg</span>
                                </div>
                                <span class="card-badge card-badge-@(r.Ultima.ClasificacionColor == "orange" ? "warning" : r.Ultima.ClasificacionColor)">
                                    @r.Ultima.Clasificacion
                                </span>
                            </div>
                            <div class="card-subtitle mt-1">
                                Última: @FormatFecha(r.Ultima.Fecha)
                                @if (r.Ultima.Pulso > 0) { <span>· Pulso: @r.Ultima.Pulso</span> }
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="text-muted" style="font-size: 0.85rem;">@r.Total medición@(r.Total != 1 ? "es" : "")</span>
                                <span class="text-primary" style="font-size: 0.85rem;">Ver historial →</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [SupplyParameterFromQuery] public string? PacienteId { get; set; }

    private List<PresionArterial> mediciones = new();
    private List<Paciente> pacientes = new();
    private Paciente? pacienteActual;
    private PresionArterial formModel = new();
    private PresionArterial? editingItem;
    private bool isLoading = true;
    private bool showForm = false;
    private bool isSaving = false;
    private string? errorMessage;

    // Chart
    private bool showChart = false;

    // Export Excel
    private bool showExport = false;
    private bool exportAllRecords = true;
    private DateTime? exportFechaDesde;
    private DateTime? exportFechaHasta;
    private string? exportError;

    // Import Excel
    private bool showImport = false;
    private bool isImporting = false;
    private List<PresionArterial> importPreview = new();
    private string? importError;
    private string? importSuccess;
    private int importTotalRows;

    private List<PresionArterial> pacienteMediciones =>
        mediciones.Where(m => m.PacienteId == PacienteId).ToList();

    private List<ResumenPaciente> resumenPacientes = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        var loadMediciones = PresionService.GetAllAsync();
        var loadPacientes = PacienteService.GetAllAsync();
        mediciones = await loadMediciones;
        pacientes = await loadPacientes;

        if (!string.IsNullOrEmpty(PacienteId))
            pacienteActual = pacientes.FirstOrDefault(p => p.Id == PacienteId);

        resumenPacientes = mediciones
            .GroupBy(m => m.PacienteId)
            .Select(g => new ResumenPaciente
            {
                PacienteId = g.Key,
                PacienteNombre = g.First().PacienteNombre,
                Total = g.Count(),
                Ultima = g.First()
            })
            .OrderBy(r => r.PacienteNombre)
            .ToList();

        isLoading = false;
    }

    private void ShowNewForm()
    {
        editingItem = null;
        formModel = new PresionArterial
        {
            Fecha = DateTime.Now.ToString("yyyy-MM-dd"),
            Hora = DateTime.Now.ToString("HH:mm"),
            PacienteId = PacienteId ?? string.Empty
        };
        showForm = true;
    }

    private void Edit(PresionArterial item)
    {
        editingItem = item;
        formModel = new PresionArterial
        {
            Id = item.Id,
            PacienteId = item.PacienteId,
            PacienteNombre = item.PacienteNombre,
            Sistolica = item.Sistolica,
            Diastolica = item.Diastolica,
            Pulso = item.Pulso,
            Fecha = item.Fecha,
            Hora = item.Hora,
            Notas = item.Notas,
            UserId = item.UserId,
            CreatedAt = item.CreatedAt
        };
        showForm = true;
    }

    private async Task Save()
    {
        var pacienteId = !string.IsNullOrEmpty(PacienteId) ? PacienteId : formModel.PacienteId;
        if (string.IsNullOrWhiteSpace(pacienteId))
        {
            errorMessage = "Selecciona un paciente";
            return;
        }
        formModel.PacienteId = pacienteId;

        if (formModel.Sistolica <= 0 || formModel.Diastolica <= 0)
        {
            errorMessage = "Los valores de presión son obligatorios";
            return;
        }
        if (string.IsNullOrWhiteSpace(formModel.Fecha))
        {
            errorMessage = "La fecha es obligatoria";
            return;
        }

        isSaving = true;
        errorMessage = null;

        formModel.PacienteNombre = pacientes.FirstOrDefault(p => p.Id == formModel.PacienteId)?.Nombre ?? "";

        if (editingItem != null)
        {
            var (success, error) = await PresionService.UpdateAsync(formModel);
            if (!success) { errorMessage = error; isSaving = false; return; }
        }
        else
        {
            var (success, error, _) = await PresionService.AddAsync(formModel);
            if (!success) { errorMessage = error; isSaving = false; return; }
        }

        isSaving = false;
        CancelForm();
        await LoadData();
    }

    private async Task Delete(PresionArterial item)
    {
        await PresionService.DeleteAsync(item.Id);
        await LoadData();
    }

    private void CancelForm()
    {
        showForm = false;
        editingItem = null;
        formModel = new();
        errorMessage = null;
    }

    private RenderFragment RenderForm() => __builder =>
    {
        <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-4">
                <h5 class="mb-3">@(editingItem != null ? "Editar" : "Nueva") Medición</h5>

                @if (pacienteActual == null)
                {
                    <div class="form-group mb-3">
                        <label class="form-label-modern">Paciente *</label>
                        <select class="form-input" @bind="formModel.PacienteId">
                            <option value="">Seleccionar paciente...</option>
                            @foreach (var p in pacientes)
                            {
                                <option value="@p.Id">@p.Nombre</option>
                            }
                        </select>
                    </div>
                }

                <div class="form-grid-2 mb-3">
                    <div class="form-group">
                        <label class="form-label-modern">Fecha *</label>
                        <input class="form-input" @bind="formModel.Fecha" placeholder="yyyy-mm-dd" />
                    </div>
                    <div class="form-group">
                        <label class="form-label-modern">Hora</label>
                        <input class="form-input" @bind="formModel.Hora" placeholder="HH:mm" />
                    </div>
                </div>

                <div class="form-grid-2 mb-3">
                    <div class="form-group">
                        <label class="form-label-modern">Sistólica (mmHg) *</label>
                        <input type="number" class="form-input" @bind="formModel.Sistolica" placeholder="120" min="50" max="300" />
                    </div>
                    <div class="form-group">
                        <label class="form-label-modern">Diastólica (mmHg) *</label>
                        <input type="number" class="form-input" @bind="formModel.Diastolica" placeholder="80" min="30" max="200" />
                    </div>
                </div>

                <div class="form-grid-2 mb-3">
                    <div class="form-group">
                        <label class="form-label-modern">Pulso (lpm)</label>
                        <input type="number" class="form-input" @bind="formModel.Pulso" placeholder="72" min="30" max="250" />
                    </div>
                    <div class="form-group"></div>
                </div>

                @if (formModel.Sistolica > 0 && formModel.Diastolica > 0)
                {
                    <div class="alert alert-@(formModel.ClasificacionColor == "orange" ? "warning" : formModel.ClasificacionColor) py-2 mb-3">
                        <strong>Clasificación:</strong> @formModel.Clasificacion (@formModel.Sistolica/@formModel.Diastolica mmHg)
                    </div>
                }

                <div class="form-group mb-3">
                    <label class="form-label-modern">Notas</label>
                    <textarea class="form-input form-textarea" @bind="formModel.Notas" placeholder="Observaciones (ayuno, después de ejercicio, etc.)"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="d-flex gap-2">
                    <button class="btn-modern btn-modern-primary" @onclick="Save" disabled="@isSaving">
                        @if (isSaving) { <div class="btn-spinner"></div> }
                        Guardar
                    </button>
                    <button class="btn-modern btn-modern-secondary" @onclick="CancelForm">Cancelar</button>
                </div>
            </div>
        </div>
    };

    private static string FormatFecha(string fecha)
    {
        if (DateTime.TryParse(fecha, out var dt))
            return dt.ToString("dd/MM/yyyy");
        return fecha;
    }

    private async Task ToggleChart()
    {
        showChart = !showChart;
        if (showChart && pacienteMediciones.Count > 1)
        {
            await Task.Yield();
            StateHasChanged();
            await Task.Delay(50);
            await RenderChart();
        }
        else
        {
            await JS.InvokeVoidAsync("presionChart.destroy");
        }
    }

    private async Task RenderChart()
    {
        var ordered = pacienteMediciones
            .OrderBy(m => m.Fecha).ThenBy(m => m.Hora)
            .ToList();

        var chartData = ordered.Select(m => new
        {
            label = FormatFecha(m.Fecha) + (!string.IsNullOrEmpty(m.Hora) ? $" {m.Hora}" : ""),
            sistolica = m.Sistolica,
            diastolica = m.Diastolica,
            pulso = m.Pulso
        }).ToList();

        var json = System.Text.Json.JsonSerializer.Serialize(chartData);
        await JS.InvokeAsync<System.Text.Json.JsonElement>("presionChart.render", "presionChartCanvas", json);
    }

    private List<PresionArterial> ExportFiltered
    {
        get
        {
            var list = pacienteMediciones;
            if (exportAllRecords) return list;

            return list.Where(m =>
            {
                if (!DateTime.TryParse(m.Fecha, out var fecha)) return false;
                if (exportFechaDesde.HasValue && fecha.Date < exportFechaDesde.Value.Date)
                    return false;
                if (exportFechaHasta.HasValue && fecha.Date > exportFechaHasta.Value.Date)
                    return false;
                return true;
            }).ToList();
        }
    }

    private void ShowExportPanel()
    {
        showExport = true;
        exportAllRecords = true;
        exportFechaDesde = null;
        exportFechaHasta = null;
        exportError = null;
    }

    private RenderFragment RenderExportPanel() => __builder =>
    {
        var filtered = ExportFiltered;

        <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-4">
                <h5 class="mb-3">Exportar a Excel</h5>

                <div class="mb-3">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" id="exportAll" checked="@exportAllRecords"
                               @onchange="() => { exportAllRecords = true; }" />
                        <label class="form-check-label" for="exportAll">
                            Todas las lecturas <span class="text-muted">(@pacienteMediciones.Count)</span>
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" id="exportRange" checked="@(!exportAllRecords)"
                               @onchange="() => { exportAllRecords = false; }" />
                        <label class="form-check-label" for="exportRange">
                            Periodo específico
                        </label>
                    </div>
                </div>

                @if (!exportAllRecords)
                {
                    <div class="form-grid-2 mb-3">
                        <div class="form-group">
                            <label class="form-label-modern">Desde</label>
                            <input type="date" class="form-input" @bind="exportFechaDesde" />
                        </div>
                        <div class="form-group">
                            <label class="form-label-modern">Hasta</label>
                            <input type="date" class="form-input" @bind="exportFechaHasta" />
                        </div>
                    </div>

                    <div class="mb-3 text-muted" style="font-size: 0.9rem;">
                        @if (filtered.Count > 0)
                        {
                            <span>@filtered.Count lectura@(filtered.Count != 1 ? "s" : "") en el periodo seleccionado</span>
                        }
                        else
                        {
                            <span>No hay lecturas en el periodo indicado</span>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(exportError))
                {
                    <div class="alert alert-danger py-2">@exportError</div>
                }

                <div class="d-flex gap-2">
                    <button class="btn-modern btn-modern-primary" @onclick="ExportExcel" disabled="@(filtered.Count == 0)">
                        Exportar @filtered.Count lecturas
                    </button>
                    <button class="btn-modern btn-modern-secondary" @onclick="() => showExport = false">Cancelar</button>
                </div>
            </div>
        </div>
    };

    private async Task ExportExcel()
    {
        var data = ExportFiltered;
        if (data.Count == 0) return;

        exportError = null;

        var rows = data.Select(m => new
        {
            Fecha = FormatFecha(m.Fecha),
            m.Hora,
            Sistolica = m.Sistolica,
            Diastolica = m.Diastolica,
            Pulso = m.Pulso > 0 ? m.Pulso : (int?)null,
            Clasificacion = m.Clasificacion,
            Notas = m.Notas
        }).ToList();

        var json = System.Text.Json.JsonSerializer.Serialize(rows);
        var nombre = pacienteActual?.Nombre?.Replace(" ", "_") ?? "Paciente";
        var fileName = $"PresionArterial_{nombre}_{DateTime.Now:yyyyMMdd}.xlsx";

        var result = await JS.InvokeAsync<System.Text.Json.JsonElement>("exportToExcel", json, fileName);
        if (!result.GetProperty("success").GetBoolean())
            exportError = $"Error al exportar: {result.GetProperty("error").GetString()}";
        else
            showExport = false;
    }

    private RenderFragment RenderImportPanel() => __builder =>
    {
        <div class="card mb-4 border-0 shadow-sm" style="border-radius: 16px;">
            <div class="card-body p-4">
                <h5 class="mb-3">Importar desde Excel</h5>

                <div class="alert alert-info py-2 mb-3" style="font-size: 0.9rem;">
                    <strong>Formato esperado:</strong> El archivo debe tener columnas con los nombres:
                    <strong>Fecha</strong>, <strong>Hora</strong>, <strong>Sistolica</strong>, <strong>Diastolica</strong>,
                    <strong>Pulso</strong> (opcional), <strong>Notas</strong> (opcional).
                </div>

                <div class="form-group mb-3">
                    <label class="form-label-modern">Archivo Excel (.xlsx, .xls)</label>
                    <InputFile class="form-control" accept=".xlsx,.xls,.csv" OnChange="OnFileSelected" />
                </div>

                @if (!string.IsNullOrEmpty(importError))
                {
                    <div class="alert alert-danger py-2">@importError</div>
                }

                @if (!string.IsNullOrEmpty(importSuccess))
                {
                    <div class="alert alert-success py-2">@importSuccess</div>
                }

                @if (importPreview.Count > 0)
                {
                    <div class="mb-3">
                        <strong>Vista previa:</strong> @importPreview.Count lecturas encontradas
                        @if (importTotalRows > importPreview.Count)
                        {
                            <span class="text-muted"> (de @importTotalRows filas, se descartaron @(importTotalRows - importPreview.Count) sin valores de presión)</span>
                        }
                    </div>
                    <div class="table-responsive mb-3" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead style="position: sticky; top: 0; background: #f8f9fa;">
                                <tr>
                                    <th>#</th>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                    <th class="text-center">Sis</th>
                                    <th class="text-center">Dia</th>
                                    <th class="text-center">Pulso</th>
                                    <th>Clasificación</th>
                                    <th>Notas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < importPreview.Count; i++)
                                {
                                    var item = importPreview[i];
                                    <tr>
                                        <td class="text-muted">@(i + 1)</td>
                                        <td>@FormatFecha(item.Fecha)</td>
                                        <td>@(string.IsNullOrEmpty(item.Hora) ? "—" : item.Hora)</td>
                                        <td class="text-center fw-bold">@item.Sistolica</td>
                                        <td class="text-center fw-bold">@item.Diastolica</td>
                                        <td class="text-center">@(item.Pulso > 0 ? item.Pulso.ToString() : "—")</td>
                                        <td>
                                            <span class="badge bg-@(item.ClasificacionColor == "orange" ? "warning" : item.ClasificacionColor)" style="font-size: 0.75rem;">
                                                @item.Clasificacion
                                            </span>
                                        </td>
                                        <td class="text-muted" style="max-width: 150px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @(string.IsNullOrEmpty(item.Notas) ? "—" : item.Notas)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="d-flex gap-2">
                    @if (importPreview.Count > 0)
                    {
                        <button class="btn-modern btn-modern-primary" @onclick="ImportAll" disabled="@isImporting">
                            @if (isImporting) { <div class="btn-spinner"></div> }
                            Importar @importPreview.Count lecturas
                        </button>
                    }
                    <button class="btn-modern btn-modern-secondary" @onclick="CancelImport">Cancelar</button>
                </div>
            </div>
        </div>
    };

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        importError = null;
        importSuccess = null;
        importPreview.Clear();

        var file = e.File;
        if (file.Size > 5 * 1024 * 1024)
        {
            importError = "El archivo no debe superar 5 MB";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());

            var result = await JS.InvokeAsync<System.Text.Json.JsonElement>("parseExcel", base64);

            if (!result.GetProperty("success").GetBoolean())
            {
                importError = $"Error al leer el archivo: {result.GetProperty("error").GetString()}";
                return;
            }

            importTotalRows = result.GetProperty("totalRows").GetInt32();
            var data = result.GetProperty("data");

            foreach (var row in data.EnumerateArray())
            {
                importPreview.Add(new PresionArterial
                {
                    Fecha = row.GetProperty("fecha").GetString() ?? "",
                    Hora = row.GetProperty("hora").GetString() ?? "",
                    Sistolica = row.GetProperty("sistolica").GetInt32(),
                    Diastolica = row.GetProperty("diastolica").GetInt32(),
                    Pulso = row.GetProperty("pulso").GetInt32(),
                    Notas = row.GetProperty("notas").GetString() ?? ""
                });
            }

            if (importPreview.Count == 0)
                importError = "No se encontraron filas con datos de presión válidos. Verifica los nombres de las columnas.";
        }
        catch (Exception ex)
        {
            importError = $"Error al procesar el archivo: {ex.Message}";
        }
    }

    private async Task ImportAll()
    {
        if (string.IsNullOrEmpty(PacienteId) || importPreview.Count == 0) return;

        isImporting = true;
        importError = null;
        var pacienteNombre = pacienteActual?.Nombre ?? "";
        int importados = 0;
        int errores = 0;

        foreach (var item in importPreview)
        {
            item.PacienteId = PacienteId;
            item.PacienteNombre = pacienteNombre;

            var (success, error, _) = await PresionService.AddAsync(item);
            if (success)
                importados++;
            else
                errores++;
        }

        isImporting = false;
        importPreview.Clear();

        if (errores == 0)
            importSuccess = $"Se importaron {importados} lecturas correctamente.";
        else
            importSuccess = $"Se importaron {importados} lecturas. {errores} registros fallaron.";

        await LoadData();
    }

    private void CancelImport()
    {
        showImport = false;
        importPreview.Clear();
        importError = null;
        importSuccess = null;
    }

    private class ResumenPaciente
    {
        public string PacienteId { get; set; } = string.Empty;
        public string PacienteNombre { get; set; } = string.Empty;
        public int Total { get; set; }
        public PresionArterial Ultima { get; set; } = new();
    }
}
